rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create, update: if request.auth != null
        && request.auth.uid == userId;

      allow delete: if request.auth != null
        && request.auth.uid == userId;

      // Sous-collection des layouts dashboard personnalisables (Phase 1+).
      // Path : users/{uid}/dashboards/{layoutId} — synthese / dashboard:* /
      // custom:* (Phase 4). Strictement scopé à l'utilisateur authentifié.
      match /dashboards/{layoutId} {
        allow read, create, update, delete:
          if request.auth != null && request.auth.uid == userId;
      }

      // Audit Prodiges (mai 2026) — alignement avec rules prod : les 3 sous-
      // collections suivantes étaient déjà déployées en prod mais absentes du
      // code. Sans ces déclarations, un redeploy depuis le code régresserait
      // les rules de prod en bloquant l'accès à settings / kpiAlerts /
      // kpiObjectives.

      // Préférences utilisateur (extensible : sources de données actives,
      // notifications, intégrations, etc.). Path actuel :
      // users/{uid}/settings/dataSources (single doc) qui contient
      // activeAccountingSource / activeBankingSource / activeFecFolderName +
      // timestamps. Tout doc settings/{...} est strictement scopé à
      // l'utilisateur authentifié.
      match /settings/{settingId} {
        allow read, create, update, delete:
          if request.auth != null && request.auth.uid == userId;
      }

      // Cibles utilisateur sur les KPIs : alertes (seuils déclenchant une
      // notif) et objectifs (cibles avec barre de progression). Chaque doc
      // = une cible, scope strict à l'utilisateur authentifié.
      match /kpiAlerts/{alertId} {
        allow read, create, update, delete:
          if request.auth != null && request.auth.uid == userId;
      }
      match /kpiObjectives/{objectiveId} {
        allow read, create, update, delete:
          if request.auth != null && request.auth.uid == userId;
      }
    }

    match /analyses/{analysisId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && request.resource.data.kpis is map
        && request.resource.data.financialFacts is map;

      allow update: if false;

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /folders/{folderId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Connections aux logiciels comptables tiers (Pennylane, Chift, Bridge).
    // Update autorisé pour le refresh des tokens et la mise à jour des cursors de sync.
    // Les tokens sont chiffrés côté serveur (lib/server/tokenCrypto.ts) avant écriture.
    match /connections/{connectionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.provider is string
        && request.resource.data.encryptedAccessToken is string;

      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Entités comptables persistées (un doc par écriture / facture / contact / etc.).
    // Schéma générique : userId + connectionId + externalId pour idempotence + rawData JSON brut.
    // Ces collections autorisent l'update car le sync incrémental peut mettre à jour des entités existantes
    // (statut de facture qui passe de "sent" à "paid", par ex.).
    match /accounting_entries/{entryId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.connectionId is string
        && request.resource.data.externalId is string;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /invoices/{invoiceId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.connectionId is string
        && request.resource.data.externalId is string;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /ledger_accounts/{accountId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.connectionId is string
        && request.resource.data.externalId is string;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /contacts/{contactId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.connectionId is string
        && request.resource.data.externalId is string;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /journals/{journalId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.connectionId is string
        && request.resource.data.externalId is string;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /bank_accounts/{bankAccountId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.connectionId is string
        && request.resource.data.externalId is string;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /bank_transactions/{transactionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.connectionId is string
        && request.resource.data.externalId is string;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Sprint A multi-tenant (cf. docs/audit-sprint-A.md) — entité Company
    // qui regroupe les données comptables d'UNE entreprise. En Sprint A,
    // chaque user a exactement 1 Company (mode dirigeant TPE/PME).
    // En Sprint C, on étendra avec `firmId` + firm_members pour le mode
    // cabinet (1 user cabinet → N Companies dossiers clients).
    //
    // Sprint A : seul l'`ownerUserId` peut lire/écrire sa Company.
    // Sprint C : la rule sera étendue avec un OR sur firmId in
    // getUserFirms() (cf. roadmap).
    match /companies/{companyId} {
      allow read: if request.auth != null
        && resource.data.ownerUserId == request.auth.uid;

      // create : owner doit être l'utilisateur authentifié + champs
      // structurels obligatoires pour éviter les Companies "corrompues"
      // injectées côté client.
      allow create: if request.auth != null
        && request.resource.data.ownerUserId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.source is string
        && request.resource.data.status is string;

      // update : on interdit le changement d'ownerUserId (transferts
      // d'ownership = à gérer Sprint C via une route admin dédiée).
      allow update: if request.auth != null
        && resource.data.ownerUserId == request.auth.uid
        && request.resource.data.ownerUserId == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.ownerUserId == request.auth.uid;
    }

    // Journal d'audit des appels API tierces (MyUnisoft, Pennylane, Bridge,
    // Odoo, FEC). Écriture EXCLUSIVEMENT côté serveur via Admin SDK
    // (cf. lib/server/integrationAudit.ts). Aucune écriture client autorisée.
    // Les ops peuvent lire pour débugger des cas utilisateur sans accès au
    // compte ; les utilisateurs n'ont pas accès à cette collection.
    match /integration_api_audit/{eventId} {
      allow read, write: if false;
    }
  }
}
