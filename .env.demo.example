# Mode démo Sprint D — copier vers .env.local et adapter.
# Le seed-demo refuse de tourner contre la prod sans --force-prod.

NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_FIREBASE_EMULATOR=true
FIREBASE_EMULATOR_HOST=localhost:8080

DEMO_OWNER_USER_UID=demo-owner-001
DEMO_FIRM_USER_UID=demo-firm-001

# Projet Firebase fictif pour l'émulateur (pas besoin de cert).
FIREBASE_PROJECT_ID=demo-vyzor

# Variables qui peuvent rester vides en émulateur :
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
