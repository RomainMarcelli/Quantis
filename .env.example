NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Comma-separated list of admin emails with access to /pdf-parser-test and /test-kpi
NEXT_PUBLIC_ADMIN_EMAILS=

# Server-side admin emails (same format as NEXT_PUBLIC_ADMIN_EMAILS, but not exposed to client bundle)
ADMIN_EMAILS=

# Firebase Admin (server-only)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Resend (server-only)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL="Quantis <onboarding@resend.dev>"

# Google Document AI (server-only)
DOCUMENT_AI_PROJECT_ID=your_gcp_project_id
DOCUMENT_AI_LOCATION=eu
DOCUMENT_AI_PROCESSOR_ID=your_document_ai_processor_id
# Optional if GOOGLE_APPLICATION_CREDENTIALS is not configured
DOCUMENT_AI_CLIENT_EMAIL=document-ai-sa@your_project.iam.gserviceaccount.com
DOCUMENT_AI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional verbose logs for extracted structure snapshots
DOCUMENT_AI_DEBUG_STRUCTURE=false
# Optional sync page limit (Document AI online processing)
DOCUMENT_AI_SYNC_PAGE_LIMIT=30
# Optional verbose logs for parser analysis/mapping diagnostics
PDF_PARSER_DEBUG=false

# Optional base URL used for Firebase action links
APP_BASE_URL=http://localhost:3000

# Vercel Cron security (server-only)
# Must match Authorization Bearer expected by /api/cron/security-audit-cleanup
CRON_SECRET=replace_with_a_long_random_secret

# ─── Intégrations comptables (Pennylane, MyUnisoft, Odoo) — server-only ────
# Toutes les variables ci-dessous sont chargées uniquement côté serveur (jamais
# exposées au navigateur). Les tokens utilisateurs sont chiffrés en AES-256-GCM
# avant d'être stockés dans Firestore (collection `connections`).

# Clé maître de chiffrement des tokens d'intégration (REQUIS).
# Format : 32 octets hex (= 64 caractères) ou base64 (44 caractères).
# Génération : `openssl rand -hex 32` ou `openssl rand -base64 32`.
# ⚠ Ne jamais changer après mise en prod sans plan de rotation : tous les tokens
#   chiffrés deviendraient illisibles.
CONNECTOR_ENCRYPTION_KEY=replace_with_a_32_byte_hex_or_base64_key

# ─── Pennylane ─────────────────────────────────────────────────────────────
# OAuth applicatif (REQUIS pour le mode oauth2 ; les modes company_token et
# firm_token ne nécessitent que le token utilisateur côté front).
PENNYLANE_OAUTH_CLIENT_ID=your_pennylane_oauth_client_id
PENNYLANE_OAUTH_CLIENT_SECRET=your_pennylane_oauth_client_secret
# Doit correspondre EXACTEMENT à l'URI déclarée dans le dashboard Pennylane.
# Ex. en dev : http://localhost:3000/api/integrations/pennylane/callback
PENNYLANE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/pennylane/callback

# Optionnel : override des endpoints OAuth (par défaut = production Pennylane).
# PENNYLANE_OAUTH_AUTHORIZE_URL=https://app.pennylane.com/oauth/authorize
# PENNYLANE_OAUTH_TOKEN_URL=https://app.pennylane.com/oauth/token

# Optionnel : override de l'API base URL (par défaut = production).
# Pour pointer la sandbox publique : https://app.pennylane.com/api/external/v2
# PENNYLANE_API_BASE_URL=https://app.pennylane.com/api/external/v2

# Token de test sandbox utilisé par les scripts de seed et de smoke E2E.
# Optionnel — seulement nécessaire pour `npm run seed:sandbox` et
# `scripts/smoke-e2e.mts`. Inutile en prod.
PENNYLANE_TEST_TOKEN=your_pennylane_sandbox_token

# ─── MyUnisoft ─────────────────────────────────────────────────────────────
# Clé partenaire X-Third-Party-Secret (REQUIS). Fournie par MyUnisoft à
# l'enregistrement de l'app — commune à tous les utilisateurs (un partenaire
# unique → tous les cabinets/sociétés). Le JWT par société est saisi par
# l'utilisateur côté front et chiffré avec CONNECTOR_ENCRYPTION_KEY.
MYUNISOFT_PARTNER_SECRET=your_myunisoft_partner_secret

# Optionnel : override de l'API base URL (par défaut = production).
# MYUNISOFT_API_BASE_URL=https://api.myunisoft.fr

# ─── Odoo ──────────────────────────────────────────────────────────────────
# Pas de variable d'env globale — la connexion Odoo est full-utilisateur
# (instanceUrl + login + apiKey + database optionnelle saisis côté front).
# La base URL est dérivée par utilisateur depuis instanceUrl normalisée.

# ─── Assistant IA (Claude) ────────────────────────────────────────────────
# Optionnel — si absent, l'assistant IA utilise des réponses pré-générées
# (mock par KPI). Pratique en dev pour développer/démontrer l'UX sans
# consommer de quota Anthropic. À renseigner pour brancher Claude réel.
ANTHROPIC_API_KEY=

# ─── Génération PDF (rapport financier 4 pages) ────────────────────────────
# Le service `services/reports/financialReportPdf.ts` invoque un script Python
# avec reportlab pour mettre en page le PDF. Optionnel : par défaut on lance
# `python3` du PATH. À surcharger uniquement si le binaire est ailleurs (par
# ex. dans un venv ou sur un environnement Vercel custom).
# PYTHON_BIN=/usr/bin/python3
# Dépendance Python à installer côté hôte : `pip3 install reportlab`

# ─── Bridge (Open Banking PSD2, sandbox) ───────────────────────────────────
# Identifiants application Bridge — récupérés sur le dashboard Bridge.
BRIDGE_CLIENT_ID=your_bridge_client_id
BRIDGE_CLIENT_SECRET=your_bridge_client_secret
# Optionnel — base URL et version d'API. Par défaut https://api.bridgeapi.io.
# BRIDGE_BASE_URL=https://api.bridgeapi.io
# BRIDGE_VERSION=2025-01-15

# ─── Supabase Vyzor benchmark (server-only) ───────────────────────────────
# Lecture seule de la vue v_vyzor_global_stats_360_full (RLS off, anon read).
# Alimente l'indicateur 3-cercles "Top 25 / Médiane / Bas 25" sur les cartes KPI.
# Sans ces variables, /api/benchmark renvoie 503 et les indicateurs restent
# masqués silencieusement (pas d'erreur visible côté UI).
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
